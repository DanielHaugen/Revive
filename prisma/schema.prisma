// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement()) // User ID
  email     String   @unique
  password  String   // Store hashed password here
  firstName String?
  lastName  String?
  role      String   @default("operator") // "admin" | "operator"
  createdAt DateTime @default(now()) // Auto-generated timestamp
  updatedAt DateTime @updatedAt     // Auto-update timestamp

  auditLogs AuditLog[]
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  action        String   // e.g., "instance.start", "snapshot.delete", "playbook.run"
  resourceId    String?  // AWS resource ID or Prisma entity ID
  detail        String?  // Human-readable description
  correlationId String?  // Groups all audit events belonging to the same logical operation
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([correlationId])
}

model Playbook {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  steps       Step[] @relation("PlaybookSteps")
  starred     Boolean  @default(false)
}

model Step {
  id          Int      @id @default(autoincrement())
  type        String   // e.g., "start-instances", "stop-instances", "restore-instances"
  playbookId  Int
  playbook    Playbook @relation("PlaybookSteps", fields: [playbookId], references: [id], onDelete: Cascade) // Cascading delete for Playbook -> Step
  targets     Target[] @relation("StepTargets") // Multiple targets (instances) for each step
}

model Target {
  id            Int      @id @default(autoincrement())
  instanceId    String   // EC2 instance ID (e.g., "i-0454f86c03b5d679e")
  instanceName  String?   // Optional: EC2 instance name for user-friendly references
  availabilityZone String? // Optional: EC2 instance availability zone
  snapshotId    String?  // Optional: Snapshot ID (for restore operations)
  snapshotName  String?  // Optional: Snapshot Name (for better readability)
  stepId        Int
  step          Step     @relation("StepTargets", fields: [stepId], references: [id], onDelete: Cascade) // Cascading delete for Step -> Target
}

// --- Restoration Jobs ---

model RestoreJob {
  id            Int       @id @default(autoincrement())
  instanceId    String
  instanceName  String?
  snapshotId    String
  status        String    @default("running") // "running" | "completed" | "failed"
  steps         Json      @default("[]")      // ordered array of progress message strings
  correlationId String    @unique
  userId        Int?
  completedAt   DateTime?                     // set when status transitions to "completed" or "failed"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([instanceId])
}

// --- AWS Resource Cache ---

model CachedInstance {
  instanceId String   @id // e.g., "i-0454f86c03b5d679e"
  data       Json     // Full Instance JSON from DescribeInstances
  syncedAt   DateTime @default(now())
}

model CachedVolume {
  volumeId String   @id // e.g., "vol-0abc123"
  data     Json     // Full Volume JSON from DescribeVolumes
  syncedAt DateTime @default(now())
}

model CachedSnapshot {
  snapshotId String   @id // e.g., "snap-0abc123"
  data       Json     // Full Snapshot JSON from DescribeSnapshots
  syncedAt   DateTime @default(now())
}

model SyncStatus {
  id                   String    @id @default("singleton") // Only one row
  lastSyncAt           DateTime?
  lastError            String?
  inProgress           Boolean   @default(false)
  autoSyncEnabled      Boolean   @default(true)
  autoSyncIntervalSecs Int       @default(30)
  updatedAt            DateTime  @updatedAt
}
